# APPS #
#
# Arch
alt - a : open -a /Applications/Arc.app/Contents/MacOS/Arc

# Chatgpt
alt - c : open -a /Applications/Chatgpt.app/Contents/MacOS/Chatgpt

# Show date
alt - d : osascript ~/.config/skhd/applescripts/pop.scpt

# Goland
lalt - g : open -a ~/Applications/Goland.app/Contents/MacOS/goland

# Google Chrome
ralt - g : open -a /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome

# Close notifications
ralt - n : osascript ~/.config/skhd/applescripts/notifications.scpt

# Obsidian
alt - o : open -a /Applications/Obsidian.app/Contents/MacOS/Obsidian

# QuickTime
alt - q : open -a /System/Applications/QuickTime\ Player.app/Contents/MacOS/QuickTime\ Player

# Slack
lalt - s : open -a /Applications/Slack.app/Contents/MacOS/Slack

# Signal
ralt - s : open -a /Applications/Signal.app/Contents/MacOS/Signal

# Telegram
alt - t : open -a /Applications/Telegram.app/Contents/MacOS/Telegram

# Visual Studio Code
alt - v : open -a /Applications/Visual\ Studio\ Code.app/Contents/MacOS/Electron

# Wezterm
lalt - w : open -a /Applications/Wezterm.app/Contents/MacOS/wezterm

# Whatsapp
ralt - w : open -a /Applications/WhatsApp.app/Contents/MacOS/WhatsApp

# Zed
alt - z : open -a /Applications/Zed.app/Contents/MacOS/zed
